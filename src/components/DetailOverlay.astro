---
---

<!-- Detalle del punto -->
<div class="detail-overlay" id="detail-overlay" role="dialog" aria-modal="true">
	<div class="detail-card" id="detail-card">
		<div class="detail-card__content-outer">
			<div class="detail-card__content-ring">
				<div class="detail-card__content">
					<p id="detail-text"></p>
				</div>
			</div>
		</div>

		<button
			type="button"
			id="btn-close-detail"
			class="detail-card__back"
			aria-label="Volver"
		>
			<img
				src="/images/boton-de-flecha.png"
				alt="Volver"
			/>
		</button>
	</div>
</div>
