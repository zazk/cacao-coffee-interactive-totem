
<!-- Cuestionario -->
<section class="screen screen--quiz" data-screen="quiz">
	<img
		class="quiz-bg"
		src="/images/home-background.jpg"
		alt=""
		aria-hidden="true"
		loading="eager"
		decoding="async"
	/>

	<div class="quiz-screen">
		<div class="start-screen__partners">
			<img
				src="/images/logos-finales.png"
				alt="Logos de Cooperación y Gobierno"
				class="start-screen__partners-img"
				loading="eager"
				decoding="async"
			/>
		</div>

		<div class="quiz-screen__main">
			<div class="quiz-card">
				<div class="quiz-timer" id="quiz-timer">00:00</div>

				<div class="quiz-question-card">
					<h2 id="quiz-question"></h2>
				</div>

				<div class="quiz-options" id="quiz-options"></div>
			</div>
		</div>

		<div class="quiz-screen__safe">
			<img
				src="/images/logo-para-abajo-SAFE-1.png"
				alt="SAFE — Sustainable Agriculture for Forest Ecosystems"
				class="quiz-screen__safe-img"
				loading="eager"
				decoding="async"
			/>
		</div>
	</div>
</section>
