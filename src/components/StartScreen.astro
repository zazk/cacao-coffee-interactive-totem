---
---

<!-- Pantalla de inicio -->
<section class="screen screen--start active" data-screen="start">
	<div class="start-screen">
		<!-- Cabecera de logos de socios -->
		<div class="start-screen__partners">
			<img
				src="/images/logos-finales.png"
				alt="Logos de Cooperación y Gobierno"
				class="start-screen__partners-img"
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>
		</div>

		<img
			class="start-screen__bg"
			src="/images/home-background.png"
			alt=""
			aria-hidden="true"
			loading="eager"
			decoding="async"
			fetchpriority="high"
		/>
		<div class="start-screen__overlay">
			<!-- Logo PNG -->
			<img
				src="/images/logo.png"
				alt="Café y Cacao del Perú para el Mundo"
				class="logo-img"
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>
			<button type="button" class="btn-inicia" id="btn-start">INICIA</button>
			<img
				src="/images/SAFE_HD_Emblem+Title_Compact_White_GreenBG.png"
				alt="SAFE — Sustainable Agriculture for Forest Ecosystems"
				class="start-screen__safe-logo"
				loading="eager"
				decoding="async"
			/>
		</div>
	</div>
</section>
